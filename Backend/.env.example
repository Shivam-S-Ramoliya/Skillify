PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_secure_jwt_access_secret_key
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_key
NODE_ENV=development

# Email Configuration (Brevo)
BREVO_API_KEY=your_brevo_api_key
BREVO_SMTP_API_KEY=your_brevo_smtp_api_key
BREVO_SENDER_EMAIL=your_verified_sender_email
BREVO_SENDER_NAME=Skillify

# Nodemailer Gmail SMTP (Backup)
# EMAIL_USER=your_gmail_username
# EMAIL_PASS=your_gmail_app_password
# EMAIL_FROM=your_from_email_address

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_URL=your_cloudinary_url
